# ── Database (Docker) ──────────────────────────────────────────────────────────
# Port 5433 avoids conflicts with any local Postgres installation on 5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tradeconnect

# ── Better Auth ────────────────────────────────────────────────────────────────
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-random-secret-here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── Google Maps Geocoding (optional) ──────────────────────────────────────────
# Without this, postcodes are given random UK-area coordinates.
# Enable "Geocoding API" in Google Cloud Console, then paste the key below.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
